---
import Layout from '../layouts/Layout.astro';
import ImageResizer from '../components/ImageResizer.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';

const faqs = [
	{
		question: 'How do I resize an image without losing quality?',
		answer: 'Drop your JPG, PNG, or WebP onto the tool above and pick one of two modes: Exact Dimensions (type a width and height in pixels, with an optional "maintain aspect ratio" lock) or Percentage Scale (drag a slider to shrink to e.g. 50% of the original). The tool decodes your image locally, redraws it onto a canvas at the target size, and re-exports it — entirely in your browser, so the file is never uploaded. Downsizing always looks sharp because there are more source pixels than target pixels; enlarging past the original will start to look soft, which is a property of scaling, not a bug.',
	},
	{
		question: 'Does this image resizer upload my photos?',
		answer: 'No. Resizing runs entirely on your device using the browser’s built-in Canvas API. Your image is decoded into memory, drawn onto a canvas at the size you chose, and re-exported — nothing is ever sent to a server. You can even use the tool offline once the page has loaded.',
	},
	{
		question: 'Should I use exact dimensions or a percentage scale?',
		answer: 'Use exact dimensions when you have a target slot to fill — a featured image that must be 1200×630 for social, a thumbnail that must be 800×600, an email header of a fixed width. Use percentage scale when you just want "half the size" or "a third the size" without caring about the precise pixel count, which is common for shrinking photos before emailing or messaging them. Both modes keep the aspect ratio by default so nothing ends up stretched.',
	},
	{
		question: 'What happens to transparency when I resize a PNG or WebP?',
		answer: 'PNG and WebP both support an alpha channel, and the canvas preserves transparency when you resize into either format — a transparent PNG resized stays transparent. If you have a transparent image and need a JPEG instead, JPEG has no alpha channel, so transparent pixels are filled with white (not black) to keep the result looking clean. Keep the output as PNG or WebP if you need the transparency to survive.',
	},
	{
		question: 'Is there a file size or resolution limit?',
		answer: 'There is no artificial upload limit because nothing uploads — the only constraint is your device’s available memory for decoding a very large image. Photos from a modern phone (4000×3000 and up) resize in under a second. If you queue an enormous file and the tab hangs, it is usually the device running low on memory rather than the tool being slow.',
	},
	{
		question: 'Is this image resizer free?',
		answer: 'Yes, completely — no sign-up, no watermark, no limit on how many images you resize. It runs in your browser so there is no server cost to recover with fees or usage caps.',
	},
	{
		question: 'Should I compress my image after resizing it?',
		answer: 'Resizing changes the pixel dimensions; compression changes the file size. They solve different problems, and you often want both — resize to the right dimensions for where the image will be shown, then compress to drop the remaining bytes. If you resized for the web, fire the image through our compressor next to shrink the file size as well.',
	},
];
---

<Layout
	title="Resize Images Online — Free, Private, No Upload"
	description="Resize JPG, PNG, and WebP images free and 100% in your browser. Change image dimensions or scale by percentage — no uploads, no sign-up, no watermark."
	keywords="resize image, image resizer, change image dimensions, scale image, resize JPEG, resize PNG, resize WebP, resize image online, free image resizer, resize photo, image size changer, resize image to specific size"
	canonicalPath="/resize-image"
	ogImage="/web-app-manifest-512x512.png"
	appName="Resize Images Online"
	appDescription="Free, 100% private image resizer for JPG, PNG, and WebP. Change image dimensions or scale by percentage entirely in the browser with no uploads and no sign-up."
	appFeatureList={[
		'Resize JPEG, PNG, and WebP images',
		'Exact dimensions (width × height) with aspect-ratio lock',
		'Percentage scale (1%–200%)',
		'Live original → new dimension preview',
		'100% client-side processing via the Canvas API',
		'No uploads and no sign-up',
	]}
	appIdSlug="resize-app"
>
	<div class="fixed right-4 top-4 z-50 sm:right-6 sm:top-6">
		<ThemeToggle client:load />
	</div>

	<main class="mx-auto flex min-h-screen max-w-3xl flex-col px-5 py-14 transition-colors duration-300 sm:py-20">
		<!-- Hero -->
		<section class="flex flex-col items-center text-center">
			<div class="mb-6 flex items-center gap-2.5 rounded-full border border-emerald-200 bg-emerald-50 px-3.5 py-1.5 text-xs font-medium text-emerald-700 transition-colors duration-300 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-300">
				<span class="flex h-2 w-2 rounded-full bg-emerald-500" />
				100% Private · Nothing leaves your device
			</div>

			<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-500 shadow-lg shadow-emerald-500/25 transition-colors duration-300 dark:bg-emerald-400 dark:shadow-emerald-500/40">
				<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="3" y="3" width="18" height="18" rx="2" />
					<path d="M3 9h18" />
					<path d="M9 21V9" />
				</svg>
			</div>

			<h1 class="mt-6 text-3xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-4xl">
				Resize Images Online
			</h1>
			<p class="mt-3 max-w-xl text-base text-neutral-500 transition-colors duration-300 dark:text-slate-400 sm:text-lg">
				Change the dimensions of JPG, PNG, and WebP images in your browser — exact pixels or a percentage scale. Live before/after sizes, no uploads, no sign-up, no watermark.
			</p>
		</section>

		<!-- Tool card -->
		<section class="mt-10 rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm transition-colors duration-300 dark:border-slate-700 dark:bg-slate-800 sm:p-7">
			<ImageResizer client:only="react" />
		</section>

		<!-- Funnel CTAs: cross-link the triangle (Compressor + EXIF stripper) -->
		<section class="mt-6 space-y-2">
			<!-- CTA 1 → Compressor -->
			<div class="overflow-hidden rounded-2xl border border-sky-200 bg-sky-50 px-5 py-5 transition-colors duration-300 dark:border-sky-900/60 dark:bg-sky-950/40 sm:px-6">
				<div class="flex flex-col items-center gap-3 text-center sm:flex-row sm:justify-between sm:text-left">
					<div class="flex items-center gap-3">
						<span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-sky-100 text-sky-700 transition-colors duration-300 dark:bg-sky-900/60 dark:text-sky-300">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
								<polyline points="7 10 12 15 17 10" />
								<line x1="12" y1="15" x2="12" y2="3" />
							</svg>
						</span>
						<p class="text-sm text-sky-800 transition-colors duration-300 dark:text-sky-200 sm:text-base">
							<span class="font-semibold">Resized your image?</span> Now make it load instantly — compress it to a fraction of the file size.
						</p>
					</div>
					<a
						href="/compress-image"
						class="inline-flex flex-none items-center gap-1.5 whitespace-nowrap rounded-lg bg-sky-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-sky-700 dark:bg-sky-500 dark:hover:bg-sky-400"
					>
						Compress this image now
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="5" y1="12" x2="19" y2="12" />
							<polyline points="12 5 19 12 12 19" />
						</svg>
					</a>
				</div>
			</div>

			<!-- CTA 2 → EXIF stripper -->
			<div class="overflow-hidden rounded-2xl border border-amber-200 bg-amber-50 px-5 py-5 transition-colors duration-300 dark:border-amber-900/60 dark:bg-amber-950/40 sm:px-6">
				<div class="flex flex-col items-center gap-3 text-center sm:flex-row sm:justify-between sm:text-left">
					<div class="flex items-center gap-3">
						<span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-amber-100 text-amber-700 transition-colors duration-300 dark:bg-amber-900/60 dark:text-amber-300">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
								<line x1="12" y1="9" x2="12" y2="13" />
								<line x1="12" y1="17" x2="12.01" y2="17" />
							</svg>
						</span>
						<p class="text-sm text-amber-800 transition-colors duration-300 dark:text-amber-200 sm:text-base">
							<span class="font-semibold">Protect your privacy.</span> Resized or not, your photo may still carry hidden GPS location and camera data — strip it.
						</p>
					</div>
					<a
						href="/remove-exif-metadata"
						class="inline-flex flex-none items-center gap-1.5 whitespace-nowrap rounded-lg bg-amber-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-400"
					>
						Strip EXIF & GPS Metadata
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="5" y1="12" x2="19" y2="12" />
							<polyline points="12 5 19 12 12 19" />
						</svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Trust signals -->
		<section class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-3">
			<div class="flex flex-col items-center gap-1.5 text-center transition-colors duration-300 sm:items-start sm:text-left">
				<span class="flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-100 text-neutral-700 transition-colors duration-300 dark:bg-slate-800 dark:text-slate-200">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="3" y="3" width="18" height="18" rx="2" />
						<path d="M9 9h6v6H9z" />
					</svg>
				</span>
				<h3 class="text-sm font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">100% Client-Side</h3>
				<p class="text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">Runs entirely in your browser.</p>
			</div>

			<div class="flex flex-col items-center gap-1.5 text-center transition-colors duration-300 sm:items-start sm:text-left">
				<span class="flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-100 text-neutral-700 transition-colors duration-300 dark:bg-slate-800 dark:text-slate-200">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
						<path d="M9 12l2 2 4-4" />
					</svg>
				</span>
				<h3 class="text-sm font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">Zero Dependencies</h3>
				<p class="text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">Just the native Canvas API.</p>
			</div>

			<div class="flex flex-col items-center gap-1.5 text-center transition-colors duration-300 sm:items-start sm:text-left">
				<span class="flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-100 text-neutral-700 transition-colors duration-300 dark:bg-slate-800 dark:text-slate-200">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="9" />
						<path d="M12 8v4l3 3" />
					</svg>
				</span>
				<h3 class="text-sm font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">Instant</h3>
				<p class="text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">No queue, no waiting on a server.</p>
			</div>
		</section>

		<!-- SEO content -->
		<section class="mt-16">
			<div class="prose-content space-y-4 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
				<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
					Why resizing matters more than people think
				</h2>
				<p>
					A photo straight off a phone or camera is almost always the wrong size for where it's actually going. A 4000×3000 image is perfect for a print or a zoomed-in crop, but it's absurd for a blog hero, an email signature, a chat preview, or a product thumbnail where no one will ever see it larger than a few hundred pixels wide. Serving or sending all those extra pixels wastes bandwidth, makes pages slow, and bloats inboxes — for zero visible benefit. Resizing to the dimensions you actually need is the single highest-leverage thing you can do before an image goes anywhere.
				</p>
				<p>
					<strong class="font-semibold text-neutral-900 dark:text-white">How this resizer works.</strong> When you drop an image in, the browser decodes it into memory and draws it onto a canvas sized to your target. In Exact Dimensions mode you type the width and/or height in pixels; with "maintain aspect ratio" on, the missing dimension is computed from the source so nothing stretches. In Percentage Scale mode you drag a slider — 50% means half the pixels on each axis, roughly a quarter the total pixel count. The canvas is re-exported with <code class="rounded bg-neutral-100 px-1 py-0.5 text-xs dark:bg-slate-700">canvas.toBlob()</code> using the same encoder your browser uses internally — no third-party libraries, no server, nothing uploaded. The image stays on your device the entire time.
				</p>
				<p>
					<strong class="font-semibold text-neutral-900 dark:text-white">Downscaling vs upscaling.</strong> Shrinking an image is visually lossless from your eye's perspective: the canvas resamples the source with high-quality smoothing, so a 4000×3000 photo reduced to 800×600 looks crisp and clean. Enlarging is the opposite — you're asking the encoder to invent pixels that don't exist, so the result softens. There's nothing wrong with a small upscale (say 120%), but pushing a small image up to wallpaper size will look fuzzy no matter which tool you use; that's the nature of scaling, not a limitation of this one. Resize toward the dimensions you need, not away from them.
				</p>
				<p>
					And remember resizing only changes dimensions — it doesn't necessarily make the file much smaller on its own. A downsized image is usually smaller because there are fewer pixels to encode, but if file size specifically is your goal, run the result through the compressor linked above afterward. Likewise, resizing re-renders pixels through a canvas, which strips most metadata as a side effect — but if privacy is the goal, run it through the dedicated EXIF and GPS remover to be certain.
				</p>
			</div>
		</section>

		<!-- How it Works + FAQ -->
		<section class="seo-copy mt-16">
			<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
				Popular Use Cases & Image Sizes
			</h2>
			<p class="mt-4 max-w-2xl text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
				Need to resize an image for Instagram? Whether you need a 1080x1080 square for your feed or a 1080x1920 story for Reels, our Quick Presets handle the dimensions for you. You can also resize images for Discord emojis, custom Twitter/X banners, or scale down HD wallpapers to fit your screen perfectly.
			</p>
		</section>

		<section class="mt-16 space-y-10">
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
					How it works
				</h2>
				<div class="mt-4 space-y-4 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
					<p>
						Drop a JPG, PNG, or WebP onto the tool (or click to browse). Choose a mode: Exact Dimensions to set a specific width and height in pixels (with optional aspect-ratio lock), or Percentage Scale to shrink or enlarge by a percentage of the original. The tool decodes the image locally, redraws it onto an off-screen canvas at the target size with high-quality smoothing, and re-exports it entirely in your browser — then shows the original and new dimensions and file sizes. Download the resized copy with one click.
					</p>
					<p>
						<strong class="font-semibold text-neutral-900 dark:text-white">No servers, no uploads.</strong> The Canvas API is built into every modern browser, so resizing needs no npm image library and no backend. That keeps it instant, free, and private — your photos never travel across the network, and you can use the tool offline after the first page load.
					</p>
				</div>
			</div>

			<div>
				<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
					Frequently asked questions
				</h2>
				<div class="mt-5 divide-y divide-neutral-200 overflow-hidden rounded-2xl border border-neutral-200 transition-colors duration-300 dark:divide-slate-700 dark:border-slate-700">
					{faqs.map((faq) => (
						<details class="group bg-white transition-colors duration-300 open:bg-neutral-50 dark:bg-slate-800 dark:open:bg-slate-700/40">
							<summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold text-neutral-900 transition-colors duration-300 hover:bg-neutral-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/50 focus-visible:ring-inset dark:text-white dark:hover:bg-slate-700/40 sm:px-6 sm:text-base">
								<span>{faq.question}</span>
								<svg class="h-5 w-5 flex-none text-neutral-400 transition-transform duration-300 group-open:rotate-180 dark:text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<polyline points="6 9 12 15 18 9" />
								</svg>
							</summary>
							<div class="px-5 pb-5 pt-0 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:px-6 sm:text-base">
								{faq.answer}
							</div>
						</details>
					))}
				</div>
			</div>
		</section>

		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'FAQPage',
			mainEntity: faqs.map((faq) => ({
				'@type': 'Question',
				name: faq.question,
				acceptedAnswer: { '@type': 'Answer', text: faq.answer },
			})),
		})} />

	</main>
</Layout>
