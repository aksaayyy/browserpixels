---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contact Us | HEIC to JPG Converter — browserpixels"
	description="Get in touch with the team behind the free, private HEIC to JPG converter. Questions, bug reports, and feature ideas welcome — we reply within 1-2 business days."
	canonicalPath="/contact"
>
	<main class="mx-auto max-w-3xl px-5 py-14 transition-colors duration-300 sm:py-20">
		<header class="mb-10">
			<h1 class="text-3xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-4xl">
				Contact Us
			</h1>
			<p class="mt-3 max-w-xl text-base text-neutral-500 transition-colors duration-300 dark:text-slate-400 sm:text-lg">
				Questions, bug reports, or feature ideas — send them our way.
			</p>
		</header>

		<div class="space-y-10">
			{/* Quick contact details */}
			<section class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm transition-colors duration-300 dark:border-slate-700 dark:bg-slate-800 sm:p-6">
				<h2 class="text-lg font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">
					Email us directly
				</h2>
				<p class="mt-2 text-sm text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
					For anything that doesn't need a form, reach us at
					<a class="font-medium text-emerald-700 underline decoration-emerald-300 underline-offset-2 transition-colors duration-300 hover:decoration-emerald-500 dark:text-emerald-400 dark:decoration-emerald-700" href="mailto:hello@browserpixels.com">hello@browserpixels.com</a>.
				</p>
				<p class="mt-2 text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">
					We typically reply within 1–2 business days.
				</p>
			</section>

			{/* Contact form — 100% client-side. There is no server endpoint:
			    submitting opens the visitor's own email client with the subject and
			    body pre-filled. No data ever leaves their machine via our site. */}
			<section class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm transition-colors duration-300 dark:border-slate-700 dark:bg-slate-800 sm:p-7">
				<h2 class="text-lg font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">
					Send a message
				</h2>
				<form id="contact-form" class="mt-5 space-y-5">
					<div>
						<label for="name" class="block text-sm font-medium text-neutral-700 transition-colors duration-300 dark:text-slate-200">
							Name
						</label>
						<input
							type="text"
							id="name"
							name="name"
							required
							autocomplete="name"
							class="mt-1.5 block w-full rounded-xl border border-neutral-300 bg-white px-3.5 py-2.5 text-sm text-neutral-900 shadow-sm transition-colors duration-300 placeholder:text-neutral-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/30 focus:outline-none dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-slate-500 sm:text-base"
							placeholder="Your name"
						/>
					</div>

					<div>
						<label for="email" class="block text-sm font-medium text-neutral-700 transition-colors duration-300 dark:text-slate-200">
							Email
						</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							autocomplete="email"
							class="mt-1.5 block w-full rounded-xl border border-neutral-300 bg-white px-3.5 py-2.5 text-sm text-neutral-900 shadow-sm transition-colors duration-300 placeholder:text-neutral-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/30 focus:outline-none dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-slate-500 sm:text-base"
							placeholder="you@example.com"
						/>
					</div>

					<div>
						<label for="message" class="block text-sm font-medium text-neutral-700 transition-colors duration-300 dark:text-slate-200">
							Message
						</label>
						<textarea
							id="message"
							name="message"
							rows="5"
							required
							class="mt-1.5 block w-full rounded-xl border border-neutral-300 bg-white px-3.5 py-2.5 text-sm text-neutral-900 shadow-sm transition-colors duration-300 placeholder:text-neutral-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/30 focus:outline-none dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-slate-500 sm:text-base"
							placeholder="How can we help?"
						></textarea>
					</div>

					<button
						type="submit"
						class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-emerald-500/25 transition-colors duration-300 hover:bg-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 dark:bg-emerald-400 dark:text-emerald-950 dark:shadow-emerald-500/40 dark:hover:bg-emerald-300 sm:w-auto sm:px-7"
					>
						Send message
					</button>
				</form>
				{/* Inline client-side handler — opens the visitor's mail client with a
				    pre-filled email. encodeURIComponent keeps line breaks/spaces intact
				    so the body reads cleanly in Gmail/Outlook/Apple Mail. */}
				<script is:inline>
					(function () {
						var form = document.getElementById('contact-form');
						if (!form) return;
						form.addEventListener('submit', function (e) {
							e.preventDefault();
							var name = form.querySelector('#name').value.trim();
							var email = form.querySelector('#email').value.trim();
							var message = form.querySelector('#message').value.trim();

							var subject = 'Message from ' + (name || 'a visitor');
							var body =
								'Name: ' + name + '\n' +
								'Email: ' + email + '\n\n' +
								'Message:\n' + message;

							var mailto =
								'mailto:hello@browserpixels.com' +
								'?subject=' + encodeURIComponent(subject) +
								'&body=' + encodeURIComponent(body);

							window.location.href = mailto;
						});
					})();
				</script>
				<p class="mt-4 text-xs text-neutral-400 transition-colors duration-300 dark:text-slate-500">
					Submitting opens your own email app — nothing is sent through our site, so your message never touches a server until you press send. See our <a class="font-medium text-emerald-700 underline decoration-emerald-300 underline-offset-2 transition-colors duration-300 hover:decoration-emerald-500 dark:text-emerald-400 dark:decoration-emerald-700" href="/privacy">Privacy Policy</a>.
				</p>
			</section>
		</div>

		<footer class="mt-12">
			<a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 transition-colors duration-300 hover:text-emerald-600 dark:text-emerald-400 dark:hover:text-emerald-300">
				← Back to the converter
			</a>
		</footer>
	</main>
</Layout>
