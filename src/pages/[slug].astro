---
import Layout from '../layouts/Layout.astro';
import ImageResizer from '../components/ImageResizer.tsx';
import ImageCompressor from '../components/ImageCompressor.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';
import { resizeUseCases } from '../data/resize-use-cases';
import { compressUseCases } from '../data/compress-use-cases';

// Programmatic-SEO landing pages for both the Image Resizer and the Image
// Compressor. One static page per use case is generated here from the two data
// files; the URL is the use-case slug (e.g. browserpixels.com/resize-image-for-instagram
// or .../compress-image-to-1mb). Each object carries a `tool` discriminator
// ('resizer' | 'compressor') that decides which React component renders and how
// the SEO copy / FAQ / cross-links are derived, so a single template serves
// both tools without per-tool branches littering the markup.
export async function getStaticPaths() {
	// Merge both sets into one path list. Both share a `slug` namespace, so
	// any collision would surface as a duplicate-path build error — which is
	// what we want (slugs must stay unique across tools).
	const all = [...resizeUseCases, ...compressUseCases];
	return all.map((useCase) => ({
		params: { slug: useCase.slug },
		props: { useCase },
	}));
}

const { useCase } = Astro.props;
const isResizer = useCase.tool === 'resizer';
const isCompressor = useCase.tool === 'compressor';

// Tool-aware derived values. The resizer's "target" is a dimension or scale;
// the compressor's is a quality level. The UI description, FAQs, feature list,
// and the component preset props all branch on these typed handles so the union
// type narrows cleanly (a bare boolean flag wouldn't narrow `ResizeUseCase |
// CompressUseCase`, so we keep typed references the markup can use safely).
const resizer = isResizer ? (useCase as (typeof resizeUseCases)[number]) : null;
const compressor = isCompressor ? (useCase as (typeof compressUseCases)[number]) : null;
const targetLabel = resizer
	? resizer.presetMode === 'percent'
		? `${resizer.presetPercent}% scale`
		: `${resizer.presetWidth}×${resizer.presetHeight}`
	: undefined;
const compressorLabel = compressor?.presetLabel;

// Per-page FAQs are derived from the use case so the FAQPage JSON-LD stays in
// sync with the visible text. Keep these factual and tied to the preset.
const faqs = isResizer
	? [
			{
				question: `How do I resize an image to ${targetLabel}?`,
				answer: `Drop your JPG, PNG, or WebP onto the tool above. It loads already set to ${targetLabel} for the "${useCase.title}" preset — just click Resize Image and download the result. Everything runs in your browser, so the file is never uploaded, and you can tweak the dimensions manually first if you need a different size.`,
			},
			{
				question: 'Does this resizer upload my photo?',
				answer: 'No. Resizing runs entirely on your device using the browser’s built-in Canvas API. Your image is decoded into memory, drawn onto a canvas at the target size, and re-exported — nothing is ever sent to a server. You can even use the tool offline once the page has loaded.',
			},
			{
				question: `Is this ${useCase.title.toLowerCase()} tool free?`,
				answer: 'Yes, completely — no sign-up, no watermark, no limit on how many images you resize. It runs in your browser so there is no server cost to recover with fees or usage caps.',
			},
		]
	: // isCompressor
		[
			{
				question: `How do I compress an image to "${useCase.title}"?`,
				answer: `Drop your JPG, PNG, or WebP onto the tool above. It loads already set to the quality preset this page targets (${compressorLabel}) — just click to compress and download the lighter copy. Everything runs in your browser, so the file is never uploaded, and you can drag the quality slider to fine-tune the size/quality trade-off before compressing.`,
			},
			{
				question: 'Does this image compressor upload my photos?',
				answer: 'No. Compression runs entirely on your device using the browser’s built-in Canvas API. Your image is decoded into memory, redrawn onto a canvas, and re-exported at the quality you chose — nothing is ever sent to a server. You can even use it offline once the page has loaded.',
			},
			{
				question: `Is this ${useCase.title.toLowerCase()} tool free?`,
				answer: 'Yes, completely — no sign-up, no watermark, no limit on how many images you compress. It runs in your browser so there is no server cost to recover with fees or usage caps.',
			},
		];

const SITE = 'https://browserpixels.com';
const canonicalURL = new URL(`/${useCase.slug}/`, SITE).href;

// Same-tool siblings for the internal-link section at the bottom (topical
// depth around the tool the page is about). The cross-TOOL pivot — resize →
// compress or compress → resize — is handled by the funnel CTA further down,
// so this section stays focused on the same tool's other presets.
const siblingResizers = resizeUseCases.filter((u) => u.slug !== useCase.slug);
const siblingCompressors = compressUseCases.filter((u) => u.slug !== useCase.slug);

// Hub link for the tool the page is about, used by the internal-link section
// and the breadcrumb. The resizer's hub is /resize-image; the compressor's is
// /compress-image.
// breadcrumb; the cross-link block points at the OTHER hub.
const hubPath = isResizer ? '/resize-image' : '/compress-image';
---

<Layout
	title={useCase.title}
	description={useCase.description}
	keywords={
		isResizer
			? `resize image, ${useCase.title.toLowerCase()}, resize photo, image resizer, ${targetLabel}, free image resizer, resize image online`
			: `image compressor, ${useCase.title.toLowerCase()}, compress image, reduce image file size, ${compressorLabel}, free image compressor, compress image online`
	}
	canonicalPath={`/${useCase.slug}`}
	ogImage="/web-app-manifest-512x512.png"
	appName={useCase.title}
	appDescription={useCase.description}
	appFeatureList={
		isResizer
			? [
					`Resize to ${targetLabel}`,
					'Supports JPG, PNG, and WebP',
					'100% client-side via the Canvas API',
					'No uploads and no sign-up',
				]
			: [
					`Compress at ${compressorLabel} quality`,
					'Supports JPG, PNG, and WebP',
					'100% client-side via the Canvas API',
					'No uploads and no sign-up',
				]
	}
	appIdSlug={`${useCase.slug}-app`}
>
	<div class="fixed right-4 top-4 z-50 sm:right-6 sm:top-6">
		<ThemeToggle client:load />
	</div>

	<main class="mx-auto flex min-h-screen max-w-3xl flex-col px-5 py-14 transition-colors duration-300 sm:py-20">
		<!-- Hero -->
		<section class="flex flex-col items-center text-center">
			<div class="mb-6 flex items-center gap-2.5 rounded-full border border-emerald-200 bg-emerald-50 px-3.5 py-1.5 text-xs font-medium text-emerald-700 transition-colors duration-300 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-300">
				<span class="flex h-2 w-2 rounded-full bg-emerald-500" />
				100% Private · Nothing leaves your device
			</div>

			<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-500 shadow-lg shadow-emerald-500/25 transition-colors duration-300 dark:bg-emerald-400 dark:shadow-emerald-500/40">
				{isResizer ? (
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="3" y="3" width="18" height="18" rx="2" />
						<path d="M3 9h18" />
						<path d="M9 21V9" />
					</svg>
				) : (
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
						<polyline points="7 10 12 15 17 10" />
						<line x1="12" y1="15" x2="12" y2="3" />
					</svg>
				)}
			</div>

			<h1 class="mt-6 text-3xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-4xl">
				{useCase.h1}
			</h1>
			<p class="mt-3 max-w-xl text-base text-neutral-500 transition-colors duration-300 dark:text-slate-400 sm:text-lg">
				{useCase.description}
			</p>
		</section>

		<!-- Tool card (pre-configured to the use-case dimensions / quality) -->
		<section class="mt-10 rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm transition-colors duration-300 dark:border-slate-700 dark:bg-slate-800 sm:p-7">
			{isResizer ? (
				<ImageResizer
					client:only="react"
					presetMode={resizer!.presetMode}
					presetWidth={resizer!.presetWidth}
					presetHeight={resizer!.presetHeight}
					presetPercent={resizer!.presetPercent}
				/>
			) : (
				<ImageCompressor
					client:only="react"
					presetQuality={compressor!.presetQuality}
					presetLabel={compressor!.presetLabel}
				/>
			)}
		</section>

		<!-- Use-case copy -->
		<section class="mt-10">
			<div class="space-y-4 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
				<p>{useCase.copy}</p>
				<p>
					{isResizer
						? 'The tool runs entirely in your browser using the Canvas API — your image is decoded locally, redrawn to the target size, and re-exported with one click. Nothing is uploaded, there’s no sign-up, and no watermark. That keeps it free and instant.'
						: 'The tool runs entirely in your browser using the Canvas API — your image is decoded locally, re-encoded at the chosen quality, and downloaded with one click. Nothing is uploaded, there’s no sign-up, and no watermark. That keeps it free and instant.'}
				</p>
			</div>
		</section>

		<!-- Funnel CTAs: cross-link the triangle (the "other" tool + EXIF stripper) -->
		<section class="mt-10 space-y-2">
			<div class="overflow-hidden rounded-2xl border border-sky-200 bg-sky-50 px-5 py-5 transition-colors duration-300 dark:border-sky-900/60 dark:bg-sky-950/40 sm:px-6">
				<div class="flex flex-col items-center gap-3 text-center sm:flex-row sm:justify-between sm:text-left">
					<div class="flex items-center gap-3">
						<span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-sky-100 text-sky-700 transition-colors duration-300 dark:bg-sky-900/60 dark:text-sky-300">
							{isResizer ? (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
									<polyline points="7 10 12 15 17 10" />
									<line x1="12" y1="15" x2="12" y2="3" />
								</svg>
							) : (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<rect x="3" y="3" width="18" height="18" rx="2" />
									<path d="M3 9h18" />
									<path d="M9 21V9" />
								</svg>
							)}
						</span>
						<p class="text-sm text-sky-800 transition-colors duration-300 dark:text-sky-200 sm:text-base">
							{isResizer ? (
								<span><span class="font-semibold">Resized your image?</span> Now make it load instantly — compress it to a fraction of the file size.</span>
							) : (
								<span><span class="font-semibold">Need specific dimensions?</span> Resize your image to exact pixels or a percentage scale before (or after) you compress.</span>
							)}
						</p>
					</div>
					<a
						href={isResizer ? '/compress-image' : '/resize-image'}
						class="inline-flex flex-none items-center gap-1.5 whitespace-nowrap rounded-lg bg-sky-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-sky-700 dark:bg-sky-500 dark:hover:bg-sky-400"
					>
						{isResizer ? 'Compress this image now' : 'Resize this image now'}
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="5" y1="12" x2="19" y2="12" />
							<polyline points="12 5 19 12 12 19" />
						</svg>
					</a>
				</div>
			</div>

			<div class="overflow-hidden rounded-2xl border border-amber-200 bg-amber-50 px-5 py-5 transition-colors duration-300 dark:border-amber-900/60 dark:bg-amber-950/40 sm:px-6">
				<div class="flex flex-col items-center gap-3 text-center sm:flex-row sm:justify-between sm:text-left">
					<div class="flex items-center gap-3">
						<span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-amber-100 text-amber-700 transition-colors duration-300 dark:bg-amber-900/60 dark:text-amber-300">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
								<line x1="12" y1="9" x2="12" y2="13" />
								<line x1="12" y1="17" x2="12.01" y2="17" />
							</svg>
						</span>
						<p class="text-sm text-amber-800 transition-colors duration-300 dark:text-amber-200 sm:text-base">
							<span class="font-semibold">Protect your privacy.</span> Resized or not, your photo may still carry hidden GPS location and camera data — strip it.
						</p>
					</div>
					<a
						href="/remove-exif-metadata"
						class="inline-flex flex-none items-center gap-1.5 whitespace-nowrap rounded-lg bg-amber-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-400"
					>
						Strip EXIF & GPS Metadata
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="5" y1="12" x2="19" y2="12" />
							<polyline points="12 5 19 12 12 19" />
						</svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Related use cases for the SAME tool (internal linking / topical depth) -->
		<section class="mt-12">
			<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
				{isResizer ? 'Resize for other platforms' : 'Compress for other targets'}
			</h2>
			<p class="mt-3 text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400 sm:text-base">
				{isResizer
					? 'Looking for a different size? Try one of these pre-configured resizers:'
					: 'Looking for a different file-size target? Try one of these pre-configured compressors:'}
			</p>
			<ul class="mt-5 flex flex-wrap gap-3">
				{/* Same-tool siblings first (kept narrow to the tool the page is about) */}
				{(isResizer ? siblingResizers : siblingCompressors).map((u) => (
					<li>
						<a
							href={`/${u.slug}`}
							class="inline-flex items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-neutral-700 transition-colors duration-300 hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-emerald-700 dark:hover:bg-emerald-950/40 dark:hover:text-emerald-300"
						>
							{u.title}
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<line x1="5" y1="12" x2="19" y2="12" />
								<polyline points="12 5 19 12 12 19" />
							</svg>
						</a>
					</li>
				))}
				<li>
					<a
						href={hubPath}
						class="inline-flex items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-neutral-700 transition-colors duration-300 hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-emerald-700 dark:hover:bg-emerald-950/40 dark:hover:text-emerald-300"
					>
						{isResizer ? 'Full Image Resizer (custom sizes)' : 'Full Image Compressor (custom quality)'}
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="5" y1="12" x2="19" y2="12" />
							<polyline points="12 5 19 12 12 19" />
						</svg>
					</a>
				</li>
			</ul>
		</section>

		<!-- FAQ -->
		<section class="mt-16">
			<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
				Frequently asked questions
			</h2>
			<div class="mt-5 divide-y divide-neutral-200 overflow-hidden rounded-2xl border border-neutral-200 transition-colors duration-300 dark:divide-slate-700 dark:border-slate-700">
				{faqs.map((faq) => (
					<details class="group bg-white transition-colors duration-300 open:bg-neutral-50 dark:bg-slate-800 dark:open:bg-slate-700/40">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold text-neutral-900 transition-colors duration-300 hover:bg-neutral-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/50 focus-visible:ring-inset dark:text-white dark:hover:bg-slate-700/40 sm:px-6 sm:text-base">
							<span>{faq.question}</span>
							<svg class="h-5 w-5 flex-none text-neutral-400 transition-transform duration-300 group-open:rotate-180 dark:text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<polyline points="6 9 12 15 18 9" />
							</svg>
						</summary>
						<div class="px-5 pb-5 pt-0 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:px-6 sm:text-base">
							{faq.answer}
						</div>
					</details>
				))}
			</div>
		</section>

		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'FAQPage',
			mainEntity: faqs.map((faq) => ({
				'@type': 'Question',
				name: faq.question,
				acceptedAnswer: { '@type': 'Answer', text: faq.answer },
			})),
		})} />

		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'BreadcrumbList',
			itemListElement: [
				{
					'@type': 'ListItem',
					position: 1,
					name: isResizer ? 'Image Resizer' : 'Image Compressor',
					item: `${SITE}${hubPath}/`,
				},
				{
					'@type': 'ListItem',
					position: 2,
					name: useCase.title,
					item: canonicalURL,
				},
			],
		})} />
	</main>
</Layout>
