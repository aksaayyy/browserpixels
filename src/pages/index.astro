---
import Layout from '../layouts/Layout.astro';
import ImageConverter from '../components/ImageConverter.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';

/* Single source of truth for the FAQ: this array renders BOTH the visible
   accordion below and the FAQPage JSON-LD schema, so the structured data can
   never drift from the on-page text (Google requires them to match for rich
   results, and penalises mismatches). */
const faqs = [
	{
		question: 'How do I convert HEIC to JPG?',
		answer: 'Drag a HEIC file onto the converter above (or click to browse), and the tool reads it in your browser and re-encodes it as a standard JPG. The whole process runs client-side using JavaScript and WebAssembly, so your photo never leaves your device. Save the resulting JPG and open it on any Windows PC, Android phone, or browser.',
	},
	{
		question: 'Is it safe to convert HEIC files online?',
		answer: 'Yes. Our HEIC to JPG converter runs entirely client-side in your browser. Your HEIC files are decoded and re-encoded as JPG on your own device, so they are never transmitted over the internet. There is no server-side processing, no temporary storage, and no third party that can access your photos.',
	},
	{
		question: 'How do I convert HEIC to JPG on Windows?',
		answer: 'Windows does not open HEIC natively without codecs from the Microsoft Store. Open this page in any Windows browser, drop in your HEIC photos, and download universal JPG files you can open immediately on any Windows PC, Android device, or web browser without installing extra software.',
	},
	{
		question: 'Is this HEIC to JPG converter free?',
		answer: 'Yes, completely. The HEIC to JPG converter is free with no hidden fees, no sign-up, no watermarks, and no limits on the number of images you can convert. It is supported by ads on the page, never by selling your data.',
	},
	{
		question: 'How do I convert HEIC to JPG on iPhone?',
		answer: 'On an iPhone, open this page in Safari, tap the converter to pick a photo from your library (or the Files app), and the image is decoded and re-encoded as JPG entirely on the device. Nothing is uploaded, and you can save the finished JPG straight back to Photos or share it as usual.',
	},
	{
		question: 'Can I convert multiple HEIC files at once?',
		answer: 'Yes. Drop several images onto the converter at the same time and each one is decoded and re-encoded locally, one after another. Because there is no server, you are not capped by a per-day quota the way free server-based converters often limit you.',
	},
	{
		question: 'How do I convert WebP to JPG without losing quality?',
		answer: 'Drop your WebP file onto the converter and it decodes the image in your browser and re-encodes it as a high-quality JPG. Because the conversion happens locally at full resolution, there is no server-side compression step, so the only quality loss comes from the standard JPG encoding itself. Choose a high quality setting if available to minimize any visible artifacts.',
	},
	{
		question: 'Does this tool upload my photos to a server?',
		answer: 'No. The converter performs 100% of its work inside your browser. When you select an image, it is read into memory locally and processed there; nothing is ever sent to a server. You can even use the tool offline once the page has loaded.',
	},
];
---

<Layout>
	<!-- Dark mode toggle — fixed top-right, above all content -->
	<div class="fixed right-4 top-4 z-50 sm:right-6 sm:top-6">
		<ThemeToggle client:load />
	</div>

	<main class="mx-auto flex min-h-screen max-w-3xl flex-col px-5 py-14 transition-colors duration-300 sm:py-20">
		<!-- Hero -->
		<section class="flex flex-col items-center text-center">
			<div class="mb-6 flex items-center gap-2.5 rounded-full border border-emerald-200 bg-emerald-50 px-3.5 py-1.5 text-xs font-medium text-emerald-700 transition-colors duration-300 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-300">
				<span class="flex h-2 w-2 rounded-full bg-emerald-500" />
				100% Private · Nothing leaves your device
			</div>

			<!-- Privacy shield icon — emerald tile that lifts in dark mode -->
			<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-500 shadow-lg shadow-emerald-500/25 transition-colors duration-300 dark:bg-emerald-400 dark:shadow-emerald-500/40">
				<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
					<path d="M9 12l2 2 4-4" />
				</svg>
			</div>

			<h1 class="mt-6 text-3xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-4xl">
				Free HEIC to JPG Converter
			</h1>
			<p class="mt-3 max-w-xl text-base text-neutral-500 transition-colors duration-300 dark:text-slate-400 sm:text-lg">
				Convert HEIC to JPG instantly, 100% in your browser. A private HEIC to JPG converter that also turns WebP to JPG — your photos never leave your device.
			</p>
		</section>

		<!-- Tool card -->
		<section class="mt-10 rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm transition-colors duration-300 dark:border-slate-700 dark:bg-slate-800 sm:p-7">
			<ImageConverter client:only="react" />
		</section>

		<!-- Trust signals -->
		<section class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-3">
			<div class="flex flex-col items-center gap-1.5 text-center transition-colors duration-300 sm:items-start sm:text-left">
				<span class="flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-100 text-neutral-700 transition-colors duration-300 dark:bg-slate-800 dark:text-slate-200">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="3" y="3" width="18" height="18" rx="2" />
						<path d="M9 9h6v6H9z" />
					</svg>
				</span>
				<h3 class="text-sm font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">100% Client-Side</h3>
				<p class="text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">Runs entirely in your browser.</p>
			</div>

			<div class="flex flex-col items-center gap-1.5 text-center transition-colors duration-300 sm:items-start sm:text-left">
				<span class="flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-100 text-neutral-700 transition-colors duration-300 dark:bg-slate-800 dark:text-slate-200">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="3" y="11" width="18" height="11" rx="2" />
						<path d="M7 11V7a5 5 0 0 1 10 0v4" />
					</svg>
				</span>
				<h3 class="text-sm font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">No Uploads</h3>
				<p class="text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">Photos stay on your machine.</p>
			</div>

			<div class="flex flex-col items-center gap-1.5 text-center transition-colors duration-300 sm:items-start sm:text-left">
				<span class="flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-100 text-neutral-700 transition-colors duration-300 dark:bg-slate-800 dark:text-slate-200">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
					</svg>
				</span>
				<h3 class="text-sm font-semibold text-neutral-900 transition-colors duration-300 dark:text-white">Instant Speed</h3>
				<p class="text-sm text-neutral-500 transition-colors duration-300 dark:text-slate-400">No waiting on a server.</p>
			</div>
		</section>

		{/* SEO content about the tool — answers "what is this and why use it" while
		    naturally covering the main and supporting keywords. Visible, crawlable
		    text, not keyword-stuffed. */}
		<section class="mt-16 space-y-10">
			<div class="prose-invert">
				<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
					About this HEIC to JPG converter
				</h2>
				<div class="mt-4 space-y-4 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
					<p>
						Our free HEIC to JPG converter turns iPhone's high-efficiency HEIC photos into universally compatible JPG files — entirely inside your browser. If you have ever searched "how to convert HEIC to JPG" after transferring photos off your phone, you already know the friction: half the results demand that you upload your images to a server. This HEIC converter takes the opposite approach. There is no upload step, no account, and no waiting in a queue. You drop in a file and the conversion runs on your own CPU, so it is finished in the time it takes the page to react.
					</p>
					<p>
						That privacy guarantee is the core of the tool, but it is also what makes it fast. Because nothing travels across the network, the only limit on speed is your own hardware. Learning how to change HEIC to JPG should not mean handing your family photos to a stranger's server. Here, the HEIC to JPG converter decodes the file locally with JavaScript and WebAssembly, re-encodes the pixel data as a standard JPG, and hands it straight back to you to download. A HEIC to JPG converter free of limits, watermarks, and sign-up walls is genuinely hard to find — most "free" tools quietly cap file size or batch count to keep their hosting bill down. This one simply does not, because there is no server bill to pay.
					</p>
					<p>
						If you are wondering how to convert HEIC to JPG on Windows, the answer is the same. Windows does not open HEIC out of the box — you either install codecs from the Microsoft Store or convert the files. Pasting a folder of iPhone photos into a browser on any Windows PC and clicking "convert" is by far the simplest path, and the resulting JPGs open on Windows, Android, macOS, and every web browser without any extra software.
					</p>
					<p>
						Conversion quality matters as much as convenience. Because this HEIC to JPG converter decodes the original image at full resolution before re-encoding, you keep the detail your camera captured — there is no aggressive downscaling or extra compression pass layered on top. The only quality loss is the unavoidable one built into JPG itself, and for most photos that is invisible to the eye. The same is true on the WebP side: when you convert a WebP file to JPG, the decoded pixels are re-encoded cleanly, so a WebP to JPG converter built for speed does not have to sacrifice fidelity. Converting WebP to PNG is the right move when you need every pixel preserved, since PNG is lossless and the round trip adds no compression artifacts at all.
					</p>
					<p>
						The same engine doubles as a complete WebP converter. Modern websites frequently serve images as WebP because it compresses well, but many editing tools and older devices still prefer JPG or PNG. Use it to convert a WebP file to JPG, or convert to WebP when you want the smaller file size for the web. Prefer the classic extension? The WebP to JPEG path produces the same image with a <code class="rounded bg-neutral-100 px-1 py-0.5 text-xs dark:bg-slate-800">.jpg</code> file your apps already recognize, so a dragging a <code class="rounded bg-neutral-100 px-1 py-0.5 text-xs dark:bg-slate-800">.webp</code> to JPG conversion is just as easy. A dedicated WebP to JPG converter and WebP converter in one tool means a single bookmark covers every direction: WebP to JPG, .webp to JPG, or back to WebP.
					</p>
					<p>
						The tool is also built for real-world workflows, not single-file demos. Dropping in several images at once works the same way as one — each file is decoded and re-encoded locally, in turn, so you can move a whole batch of HEIC photos to JPG without sitting through uploads or hitting a per-day cap that free server-based converters love to enforce. Even if you only ever convert one photo at a time, the absence of a queue, a sign-in, or a waiting screen is the difference between a chore and a non-event.
					</p>
					<p>
						One last point worth making: you might notice this page is mostly text explaining the tool rather than bright banners promising the world. That is deliberate. The converter does exactly one thing and does it privately, and the content here exists to answer the questions people actually ask — how to convert HEIC to JPG, whether it is safe, how it works on Windows, and how it handles WebP — instead of dressing up a file upload form as something it is not. Everything here is free, works on iPhone and Windows, needs no installation, and runs offline once the page has loaded. Whether you landed here to fix one photo or a whole folder, the tool above is all you need.
					</p>
				</div>
			</div>
		</section>

		{/* How it Works + FAQ — SEO content below the tool. The visible text mirrors
		    the JSON-LD FAQ schema in Layout.astro so the structured data is backed by
		    real, crawlable content (required for rich results and AdSense). */}
		<section class="mt-16 space-y-10">
			<!-- How it works -->
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
					How it works
				</h2>
				<div class="mt-4 space-y-4 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:text-base">
					<p>
						Using the converter is a three-step process that happens entirely inside your browser. First, drag a HEIC or WebP file onto the tool above (or click to browse and select one from your device). Second, the file is read into your browser's memory and decoded locally — no part of it is ever sent to a server. Third, the decoded image is re-encoded as a standard JPG that you can save and open on any device.
					</p>
					<p>
						<strong class="font-semibold text-neutral-900 dark:text-white">Server-side vs. client-side conversion.</strong> Most online image converters work server-side: when you hit "upload", your photo is transmitted over the internet to a remote server, processed there, and sent back to you. That round trip has real costs — your photos leave your device (a privacy concern), you wait on network speed and a shared processing queue (a performance concern), and the operator has to pay for the servers and bandwidth (which is why those tools often show aggressive ads, impose file-size limits, or both).
					</p>
					<p>
						This tool is different. It is <strong class="font-semibold text-neutral-900 dark:text-white">100% client-side</strong>. The heavy lifting — decoding the HEIC container, reading its compressed pixel data, and re-encoding it as JPG — is performed right on your own CPU using JavaScript and WebAssembly bundled into the page. Nothing about your image travels across the network at all. You get instant conversions limited only by your own hardware, total privacy, and no file-size caps imposed by someone else's server bill.
					</p>
					<p>
						The trade-off is that all the work happens on your device, so very large batches of HEIC files will briefly use your CPU. For most everyday conversions — a handful of iPhone photos or screenshots — you will not notice it at all, and the round-trip is far faster than waiting on an upload.
					</p>
				</div>
			</div>

			<!-- Frequently asked questions (SEO accordion) — semantic <details>/
			     <summary> so the questions stay crawlable & accessible without JS,
			     and they double as click-to-expand UX. Map mirrors the FAQPage
			     JSON-LD below exactly (single source of truth: the `faqs` array). -->
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-neutral-900 transition-colors duration-300 dark:text-white sm:text-3xl">
					Frequently asked questions
				</h2>
				<div class="mt-5 divide-y divide-neutral-200 overflow-hidden rounded-2xl border border-neutral-200 transition-colors duration-300 dark:divide-slate-700 dark:border-slate-700">
					{faqs.map((faq, i) => (
						<details class="group bg-white transition-colors duration-300 open:bg-neutral-50 dark:bg-slate-800 dark:open:bg-slate-700/40">
							<summary
								class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold text-neutral-900 transition-colors duration-300 hover:bg-neutral-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/50 focus-visible:ring-inset dark:text-white dark:hover:bg-slate-700/40 sm:px-6 sm:text-base"
							>
								<span>{faq.question}</span>
								{/* Disclosure marker — rotates on open. aria-hidden as
								    summary already implies expand/collapse semantics. */}
								<svg class="h-5 w-5 flex-none text-neutral-400 transition-transform duration-300 group-open:rotate-180 dark:text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<polyline points="6 9 12 15 18 9" />
								</svg>
							</summary>
							<div class="px-5 pb-5 pt-0 text-sm leading-relaxed text-neutral-600 transition-colors duration-300 dark:text-slate-300 sm:px-6 sm:text-base">
								{faq.answer}
							</div>
						</details>
					))}
				</div>
			</div>
		</section>

		{/* FAQPage structured data — emitted from the same `faqs` array that
		    renders the visible accordion above, so Google's rich-result
		    requirement (schema must match on-page text) is guaranteed by
		    construction. */}
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'FAQPage',
			mainEntity: faqs.map((faq) => ({
				'@type': 'Question',
				name: faq.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: faq.answer,
				},
			})),
		})} />
	</main>
</Layout>
